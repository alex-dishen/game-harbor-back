generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  email      String   @unique
  password   String
  firstName  String
  lastName   String

  games UserGame[]

  @@map("users")
}

model Game {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  background_image String
  description_raw  String
  released         String
  website          String?
  created_at       DateTime @default(now())

  users            UserGame[]
  genres           GameGenre[]
  parent_platforms GamePlatform[]
  developers       GameDeveloper[]
  publishers       GamePublisher[]

  @@map("games")
}

model Platform {
  id   String @id @default(uuid()) @db.Uuid
  name String
  slug String

  games GamePlatform[]

  @@map("platforms")
}

model Genre {
  id   String @id @default(uuid()) @db.Uuid
  name String

  game_genres GameGenre[]

  @@map("genres")
}

model Developer {
  id   String @id @default(uuid()) @db.Uuid
  name String

  games GameDeveloper[]

  @@map("developers")
}

model Publisher {
  id   String @id @default(uuid()) @db.Uuid
  name String

  games GamePublisher[]

  @@map("publishers")
}

model UserGame {
  id      String @id @default(uuid()) @db.Uuid
  game_id String @db.Uuid
  user_id String @db.Uuid

  user User @relation(fields: [user_id], references: [id])
  game Game @relation(fields: [game_id], references: [id])

  @@unique([user_id, game_id])
  @@map("user_games")
}

model GameGenre {
  id       String @id @default(uuid()) @db.Uuid
  game_id  String @db.Uuid
  genre_id String @db.Uuid

  game  Game  @relation(fields: [game_id], references: [id])
  genre Genre @relation(fields: [genre_id], references: [id])

  @@unique([game_id, genre_id])
  @@map("game_genres")
}

model GamePlatform {
  id          String @id @default(uuid()) @db.Uuid
  game_id     String @db.Uuid
  platform_id String @db.Uuid

  game     Game     @relation(fields: [game_id], references: [id])
  platform Platform @relation(fields: [platform_id], references: [id])

  @@unique([game_id, platform_id])
  @@map("game_platforms")
}

model GameDeveloper {
  id           String @id @default(uuid()) @db.Uuid
  game_id      String @db.Uuid
  developer_id String @db.Uuid

  game      Game      @relation(fields: [game_id], references: [id])
  developer Developer @relation(fields: [developer_id], references: [id])

  @@map("game_developers")
}

model GamePublisher {
  id           String  @id @default(uuid()) @db.Uuid
  game_id      String? @db.Uuid
  publisher_id String? @db.Uuid

  game      Game?      @relation(fields: [game_id], references: [id])
  publisher Publisher? @relation(fields: [publisher_id], references: [id])

  @@map("game_publishers")
}
